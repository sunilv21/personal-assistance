# Required: Sarvam AI (STT + TTS)
# Get one at https://dashboard.sarvam.ai
SARVAM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Required: OpenAI (LLM)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional (defaults shown)
OPENAI_MODEL=gpt-4o-mini
SARVAM_DEFAULT_VOICE=shubh
SARVAM_DEFAULT_LANGUAGE=en-IN

# Optional: restrict CORS in production. Set to your Vercel URL.
# Leave unset to allow all origins (default).
# ALLOWED_ORIGIN=https://your-app.vercel.app
